          <option value="Togo">Togo</option>
          <option value="Tonga">Tonga</option>
          <option value="Trinidad and Tobago">Trinidad and Tobago</option>
          <option value="Tunisia">Tunisia</option>
          <option value="Turkey">Turkey</option>
          <option value="Turkmenistan">Turkmenistan</option>
          <option value="Tuvalu">Tuvalu</option>
          <option value="Uganda">Uganda</option>
          <option value="Ukraine">Ukraine</option>
          <option value="United Arab Emirates">United Arab Emirates</option>
          <option value="United Kingdom">United Kingdom</option>
          <option value="United States">United States</option>
          <option value="Uruguay">Uruguay</option>
          <option value="Uzbekistan">Uzbekistan</option>
          <option value="Vanuatu">Vanuatu</option>
          <option value="Venezuela">Venezuela</option>
          <option value="Vietnam">Vietnam</option>
          <option value="Yemen">Yemen</option>
          <option value="Zambia">Zambia</option>
          <option value="Zimbabwe">Zimbabwe</option>
        </select>

        {% render 'icon-select' %}
      </div>
    </div>
  </div>

  <div class="form__item-group">
    <div class="form__item">
      <label for="TPWebsite-{{ section.id }}" class="field-label">Website</label>
      <input type="text" id="TPWebsite-{{ section.id }}" class="input--full" name="contact[website]">
    </div>
    <div class="form__item">
      <label for="TPSocialMedia-{{ section.id }}" class="field-label">Social Media Link</label>
      <input type="text" id="TPSocialMedia-{{ section.id }}" class="input--full" name="contact[social_media]">
    </div>
  </div>

  <div class="form__item-group">
    <div class="form__item">
      <label for="TPBusinessCard-{{ section.id }}" class="field-label">Business Card (file)</label>
      <input type="file" id="TPBusinessCard-{{ section.id }}" class="input--full" {% unless section.settings.show_file_inputs %}disabled{% endunless %}>
    </div>
    <div class="form__item">
      <label for="TPResale-{{ section.id }}" class="field-label">Resale License (file)</label>
      <input type="file" id="TPResale-{{ section.id }}" class="input--full" {% unless section.settings.show_file_inputs %}disabled{% endunless %}>
    </div>
  </div>

  <div class="form__note">
    {{ section.settings.disclaimer | default: 'Note: Uploads are not transmitted via Shopify’s native contact form.' }}
  </div>

  <div class="form__actions form__item form__item--submit">
    <button type="submit" class="btn btn--solid btn--large btn--black">{{ section.settings.button_label | default: 'Submit' }}</button>
  </div>
{% endform %}

</section>

<style>
.trade-program-form { 
    max-width: 840px; margin: 0 auto; 
}
.trade-program-form .form__item-group { display: flex; flex-wrap: wrap; gap: 20px; }
.trade-program-form .form__item-group .form__item { flex: 1 1 calc(50% - 10px); }
.trade-program-form .form__item--submit { justify-content: center; }
.trade-program-form .form__note p {
    font-family: 'urw-din-semi-condensed';
    letter-spacing: 1.5px;
    text-transform: uppercase;
    text-align: center;
    margin: 0 auto 20px;
}
@media (max-width: 749px) { 
    .trade-program-form .form__item-group .form__item { flex: 1 1 100%; } 
    .trade-program-form .form__item-group { gap: 0; }
}
@media (min-width: 990px) {
    .trade-program-form .contact-form { padding: 0 6rem 10rem !important; }
    .trade-program-form .form__note p { font-size: 10px; max-width: 540px; }
    .trade-program-form .form__note { margin: 3rem 0 4rem; }
}
@media (max-width: 989px) {
    .trade-program-form .contact-form { padding: 0 3rem 8rem !important; }
    .trade-program-form .form__note p { font-size: 8px; max-width: 365px; }
    .trade-program-form .form__note { margin: 2.5rem 0 3rem; }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
  var form = document.getElementById('TradeProgramForm-{{ section.id }}');
  if (!form) return;
  form.addEventListener('submit', function () {
    var get = function (id) { var el = document.getElementById(id); return el ? el.value.trim() : ''; };
    var body = [
      'Trade Program Application',
      '--------------------------------',
      'Name: ' + get('TPFirstName-{{ section.id }}') + ' ' + get('TPLastName-{{ section.id }}'),
      'Email: ' + get('TPEmail-{{ section.id }}'),
      'Phone: ' + (get('TPCountryCode-{{ section.id }}') || '') + ' ' + get('TPPhone-{{ section.id }}'),
      'Business Name: ' + get('TPBusinessName-{{ section.id }}'),
      'Address 1: ' + get('TPAddress1-{{ section.id }}'),
      'Address 2: ' + get('TPAddress2-{{ section.id }}'),
      'City: ' + get('TPCity-{{ section.id }}'),
      'State: ' + get('TPState-{{ section.id }}'),
      'ZIP: ' + get('TPZip-{{ section.id }}'),
      'Country: ' + get('TPCountry-{{ section.id }}'),
      'Website / Social: ' + get('TPWebsite-{{ section.id }}'),
      '',
      '(Note: File uploads are not sent via Shopify contact forms.)'
    ].join('\n');
    var bodyField = document.getElementById('TPBody-{{ section.id }}');
    if (bodyField) bodyField.value = body;
  }, { passive: true });
});
</script>

{% schema %}
{
  "name": "Trade Program Form",
  "tag": "section",
  "class": "section trade-program-form-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join Our Trade Program"
    },
    {
      "type": "richtext",
      "id": "note_text",
      "label": "Intro text",
      "default": "<p>Please complete all required fields.</p>"
    },
    {
      "type": "richtext",
      "id": "disclaimer",
      "label": "Footer note",
      "default": "<p>Note: Uploads are not transmitted via Shopify’s native contact form.</p>"
    },
    {
      "type": "text",
      "id": "success_text",
      "label": "Success message",
      "default": "Thanks—your application has been submitted."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Submit"
    },
    {
      "type": "checkbox",
      "id": "show_file_inputs",
      "label": "Show file inputs (visual only)",
      "default": true
    }
  ],
  "presets": [
    { "name": "Trade Program Form" }
  ]
}
{% endschema %}
