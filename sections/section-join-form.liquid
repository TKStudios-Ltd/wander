{% comment %}
  sections/trade-program-form.liquid
{% endcomment %}

<section id="trade-program-form--{{ section.id }}" class="trade-program-form page-width">
  {% if section.settings.heading != blank %}
    <h2 class="form__title">{{ section.settings.heading }}</h2>
  {% endif %}
  {% if section.settings.note_text != blank %}
    <p class="form__note">{{ section.settings.note_text }}</p>
  {% endif %}

  {% liquid
  assign tp_form_id = 'TradeProgramForm-' | append: section.id
%}
{% form 'contact', id: tp_form_id, class: 'contact-form' %}

  {% if form.posted_successfully? %}
    <p class="form-status form-status--success">{{ section.settings.success_text | default: 'Thanks—your application has been submitted.' }}</p>
  {% endif %}

  {% if form.errors %}
    <div class="form-status form-status--error">
      <ul>
        {% for field in form.errors %}
          <li>{{ field | capitalize }} — {{ form.errors.messages[field] }}</li>
        {% endfor %}
      </ul>
    </div>
  {% endif %}

  <input type="hidden" name="contact[tags]" value="Trade Program Application">
  <textarea id="TPBody-{{ section.id }}" name="contact[body]" hidden></textarea>

  <div class="form__item-group">
    <div class="form__item">
      <label for="TPFirstName-{{ section.id }}" class="field-label">First Name*</label>
      <input type="text" id="TPFirstName-{{ section.id }}" class="input--full" name="contact[first_name]" autocapitalize="words" required>
    </div>
    <div class="form__item">
      <label for="TPLastName-{{ section.id }}" class="field-label">Last Name*</label>
      <input type="text" id="TPLastName-{{ section.id }}" class="input--full" name="contact[last_name]" autocapitalize="words" required>
    </div>
  </div>

  <div class="form__item">
    <label for="TPEmail-{{ section.id }}" class="field-label">Email*</label>
    <input type="email" id="TPEmail-{{ section.id }}" class="input--full" name="contact[email]" required>
  </div>

